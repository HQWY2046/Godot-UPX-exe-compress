[sub_resource type="GDScript" id="GDScript_wp4xf"]
script/source = "extends OptionButton
func _ready() -> void:
	var index = Global.set_dic.get(name)
	if index is int:
		selected = index
		item_selected.emit(selected)
		
func _on_item_selected(index: int) -> void:
	Global.set_dic[name] = index
"

[sub_resource type="GDScript" id="GDScript_brvut"]
script/source = "extends LineEdit
func _ready() -> void:
	var the_text = Global.set_dic.get(name)
	if the_text is String:
		text = the_text
		



func _on_focus_exited() -> void:
	Global.set_dic[name] = text


func _on_file_dialog_file_selected(path: String) -> void:
	text = path
	Global.set_dic[name] = text
"

[sub_resource type="GDScript" id="GDScript_0ha60"]
script/source = "extends Button

@onready var file_dialog: FileDialog = $FileDialog
@export var aim_line_edit: LineEdit
func _on_pressed() -> void:
	if aim_line_edit:
		if DirAccess.dir_exists_absolute(aim_line_edit.text.get_base_dir()):
			file_dialog.current_dir = aim_line_edit.text.get_base_dir()
	file_dialog.visible = true
"

[sub_resource type="GDScript" id="GDScript_4j5ol"]
script/source = "extends Button

@export var from_line_edit:LineEdit
@export var to_line_edit:LineEdit
func _on_pressed() -> void:
	if from_line_edit and to_line_edit:
		to_line_edit.text = from_line_edit.text
"

[sub_resource type="GDScript" id="GDScript_v0l8b"]
script/source = "extends OptionButton
func _ready() -> void:
	var index = Global.set_dic.get(name)
	if index is int:
		selected = index
		item_selected.emit(selected)
	else:
		selected = 0
		item_selected.emit(selected)
func _on_item_selected(index: int) -> void:
	match index:
		0:
			TranslationServer.set_locale(\"en\")
			Global.set_dic[name] = 0
		1:
			TranslationServer.set_locale(\"zh-CN\")
			Global.set_dic[name] = 1
"

[sub_resource type="GDScript" id="GDScript_p1hux"]
script/source = "extends Window

signal thread_finished
@export var animation_player: AnimationPlayer

@onready var fun: Label = $MarginContainer/HBoxContainer/fun


func _ready() -> void:
	visible = false

	
func show_win():
	fun.text = \"Word\"+str(randi_range(1,7))
	visible = true
	animation_player.play(\"idle\")


	
func hide_win():
	animation_player.stop()
	visible = false

	
	

		
"

